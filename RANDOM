#!/bin/bash

SERVICE="Wi-Fi"
IFACE="en0"

# Extract values from DHCP lease
IP=$(ipconfig getpacket $IFACE | awk '/yiaddr/ {print $3}')
ROUTER=$(ipconfig getpacket $IFACE | awk '/router/ {print $3}' | tr -d '{}')
MASK_HEX=$(ifconfig $IFACE | awk '/inet / {print $4}')

# Convert hex netmask to dotted decimal
MASK=$(printf "%d.%d.%d.%d\n" 0x${MASK_HEX:2:2} 0x${MASK_HEX:4:2} 0x${MASK_HEX:6:2} 0x${MASK_HEX:8:2})

echo "IP: $IP"
echo "Mask: $MASK"
echo "Router: $ROUTER"

# Apply manual configuration
sudo networksetup -setmanual "$SERVICE" "$IP" "$MASK" "$ROUTER"




