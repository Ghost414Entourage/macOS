#!/bin/bash

SERVICE="Wi-Fi"
IFACE="en0"

# Extract IP
IP=$(ipconfig getpacket $IFACE | awk '/yiaddr/ {print $3}')

# Extract Router
ROUTER=$(ipconfig getpacket $IFACE | awk '/router/ {print $3}' | tr -d '{}')

# Extract DNS servers (handles multiple)
DNS=$(ipconfig getpacket $IFACE | awk '/domain_name_server/ {print $3}' | tr -d '{}')

# Extract netmask (hex)
MASK_HEX=$(ifconfig $IFACE | awk '/inet / {print $4}')

# Convert hex netmask → dotted decimal
MASK=$(printf "%d.%d.%d.%d\n" \
0x${MASK_HEX:2:2} \
0x${MASK_HEX:4:2} \
0x${MASK_HEX:6:2} \
0x${MASK_HEX:8:2})

echo "IP: $IP"
echo "Mask: $MASK"
echo "Router: $ROUTER"
echo "DNS: $DNS"

# Apply static IP
sudo networksetup -setmanual "$SERVICE" "$IP" "$MASK" "$ROUTER"

# Apply static DNS
sudo networksetup -setdnsservers "$SERVICE" $DNS




