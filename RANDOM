#!/bin/sh

TABLE="blocked_ips"
COUNTRIES="ru cn"   # change ISO country codes as needed
BASE_URL="https://www.ipdeny.com/ipblocks/data/countries"

TMPFILE="$(mktemp)"

echo "Downloading GeoIP data..."

for C in $COUNTRIES; do
    curl -fsSL "$BASE_URL/${C}.zone" >> "$TMPFILE" || {
        echo "Failed to download ${C}.zone"
        rm -f "$TMPFILE"
        exit 1
    }
done

# Ensure file is not empty
if [ ! -s "$TMPFILE" ]; then
    echo "Download produced empty file. Aborting."
    rm -f "$TMPFILE"
    exit 1
fi

echo "Loading into PF table '$TABLE'..."

if pfctl -t "$TABLE" -T replace -f "$TMPFILE"; then
    echo "PF table updated successfully."
else
    echo "PF update failed."
    rm -f "$TMPFILE"
    exit 1
fi

rm -f "$TMPFILE"
exit 0






